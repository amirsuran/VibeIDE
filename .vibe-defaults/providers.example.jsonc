// ─────────────────────────────────────────────────────────────────────────────
//  .vibe/providers.json — свои LLM-провайдеры и модели (формат VibeIDE)
//
//  Это ПРИМЕР. Чтобы включить — скопируйте нужные блоки в файл .vibe/providers.json
//  рядом с этим (или переименуйте копию). Формат — JSONC: можно писать // комментарии.
//
//  ВАЖНО: после изменения СТРУКТУРЫ провайдера (id, baseURL, модели) перезапустите VibeIDE.
//  А вот значение ключа в .vibe/.env подхватывается на лету (без рестарта).
//
//  Главные принципы:
//   • Ключи API в файле providers.json НЕ хранятся. Источник ключа для "apiKeyEnv" — один из:
//       — файл .vibe/.env (строка ИМЯ=значение; gitignored, в контекст агента не попадает) — проще всего;
//       — переменная окружения ОС с тем же именем (читается при запуске процесса).
//     Либо "apiKeyRef" — ключ из защищённых настроек VibeIDE. Сам providers.json можно коммитить.
//   • "active": true|false — тумблер. Есть на провайдере И на каждой модели.
//   • Совпал "id" со встроенным провайдером → ваши поля НАКЛАДЫВАЮТСЯ поверх него (патч).
//   • "extends": "<id>" → НОВЫЙ провайдер на базе существующего (оригинал остаётся).
//   • Пишите только ОТЛИЧИЯ — остальное наследуется. Список моделей мёржится по id модели.
//   • Reasoning («думать»): "reasoning": { "effort": [...] } → слайдер усилия (шлёт reasoning_effort,
//     парсит reasoning_content). Провайдеро-специфичный тумблер размышления (напр. Moonshot/Kimi
//     "thinking") кладите в "extraBody" — он уходит в тело запроса как есть. Готовый рецепт — блок 5.
//
//  id ВСТРОЕННЫХ провайдеров (для патча по "id", для "extends" и "apiKeyRef") — копируйте отсюда:
//    openCodeZen       OpenCode Zen          openAI            OpenAI
//    openCodeGo        OpenCode Go           deepseek          DeepSeek
//    minimax           MiniMax               mistral           Mistral
//    openRouter        OpenRouter            xAI               Grok (xAI)
//    lmRoute           LM Router             openAICompatible  Совместимо с OpenAI API
//    liteLLM           LiteLLM               googleVertex      Google Vertex AI
//    gemini            Gemini                microsoftAzure    Microsoft Azure OpenAI
//    groq              Groq                  awsBedrock        AWS Bedrock
//    pollinations      Pollinations          ollama            Ollama
//    anthropic         Anthropic             vLLM / lmStudio   vLLM / LM Studio
//  (Тот же список с описаниями — команда «VibeIDE: Показать распознанные провайдеры».)
// ─────────────────────────────────────────────────────────────────────────────
{
	"version": 1,

	"providers": [

		// ── 1. Свой OpenAI-совместимый провайдер «с нуля» ──────────────────────────
		{
			"id": "my-proxy",
			"name": "Мой прокси",
			"active": true,
			"order": 10, // порядок среди ВАШИХ провайдеров (меньше = выше); без него — в конец по имени
			"protocol": "openai", // openai | anthropic | gemini
			"baseURL": "https://llm.mycorp.local/v1",
			"auth": { "type": "header", "name": "x-api-key" }, // или "bearer" / { "type":"query","name":"key" }
			"apiKeyEnv": "MYCORP_LLM_KEY", // ключ из переменной окружения
			"headers": { "x-team": "platform" }, // статические заголовки (по желанию)
			"timeoutMs": 120000,
			"models": {
				"fetch": true // авто-список из <baseURL>/v1/models (при подключённом ключе)
			}
		},

		// ── 2. Полное определение модели (когда каталога нет или нужно зафиксировать) ─
		{
			"id": "minimax",
			"name": "MiniMax",
			"active": true,
			"baseURL": "https://api.minimax.io/v1",
			"apiKeyRef": "minimax", // взять ключ из защищённых настроек
			"models": {
				"fetch": false,
				"static": [
					{
						"id": "MiniMax-M3",
						"name": "MiniMax M3 (1M)",
						"active": true,
						"default": true, // авто-выбор по умолчанию
						"pinned": true, // показывать вверху
						"contextWindow": 1000000,
						"toolFormat": "openai", // openai | anthropic | gemini | none
						"vision": true,
						"reasoning": { "canTurnOff": true, "effort": ["low", "high"] }, // effort → reasoning_effort; тумблер провайдера — в extraBody (блок 5)
						"cost": { "input": 0.3, "output": 1.2 }
					}
				]
			}
		},

		// ── 3. Переопределить ВСТРОЕННЫЙ провайдер (совпадение по id) ───────────────
		// Выключить целиком:
		{ "id": "googleVertex", "active": false },

		// Оставить у встроенного OpenRouter только 2 модели:
		{
			"id": "openRouter",
			"models": {
				"fetch": false,
				"static": [
					{ "id": "anthropic/claude-sonnet-4.5", "default": true },
					{ "id": "deepseek/deepseek-v3.2" }
				]
			}
		},

		// Выключить ОДНУ модель у провайдера (остальные как были):
		{ "id": "minimax", "models": { "static": [ { "id": "MiniMax-M2", "active": false } ] } },

		// ── 4. extends — клон встроенного как отдельный вариант (оригинал остаётся) ──
		{
			"id": "openRouter-fav",
			"extends": "openRouter",
			"name": "OpenRouter — избранное",
			"order": 20, // ниже my-proxy (order:10) в списке выбора модели
			"apiKeyRef": "openRouter",
			"models": {
				"fetch": false,
				"static": [ { "id": "x-ai/grok-4", "default": true } ]
			}
		},

		// ── 5. «Думающая» модель: reasoning + extraBody (рецепт Kimi/Moonshot K2.7) ──
		{
			"id": "kimi",
			"name": "Kimi (Moonshot)",
			"active": true,
			"baseURL": "https://api.moonshot.ai/v1",
			"apiKeyEnv": "MOONSHOT_API_KEY", // ключ из .vibe/.env
			"models": {
				"fetch": false,
				"static": [
					{
						"id": "kimi-k2.7-code",
						"name": "Kimi K2.7 Code",
						"active": true,
						"contextWindow": 262144,
						"maxOutputTokens": 32768,
						"toolFormat": "openai",
						"reasoning": { "canTurnOff": true, "effort": ["low", "medium", "high"] }, // → reasoning_effort + reasoning_content
						"extraBody": { "thinking": { "type": "enabled" } } // Moonshot-специфичный тумблер размышления (уходит в тело как есть)
					}
				]
			}
		}

	]
}
