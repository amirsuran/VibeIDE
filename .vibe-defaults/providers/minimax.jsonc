// MiniMax — OpenAI-совместимый API, статически заданные модели с ценой.
// "minimax" — встроенный id, поэтому этот блок ПАТЧИТ встроенного провайдера
// (фиксирует список моделей). Ключ: apiKeyRef берёт его из защищённых настроек VibeIDE.
{
	"version": 1,
	"providers": [
		{
			"id": "minimax",
			"name": "MiniMax",
			"baseURL": "https://api.minimax.io/v1",
			"apiKeyRef": "minimax",
			"models": {
				"fetch": false,
				"static": [
					{
						"id": "MiniMax-M3",
						"name": "MiniMax M3 (1M)",
						"default": true,
						"pinned": true,
						"contextWindow": 1000000,
						"toolFormat": "openai",
						"vision": true,
						"reasoning": { "canTurnOff": true, "effort": ["low", "high"] },
						"cost": { "input": 0.3, "output": 1.2 }
					}
				]
			}
		}
	]
}
