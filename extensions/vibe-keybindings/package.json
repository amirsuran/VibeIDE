{
  "name": "vibe-keybindings",
  "displayName": "Vibe Keybindings (IntelliJ IDEA / JetBrains style)",
  "description": "JetBrains/IntelliJ IDEA keymap for VibeIDE, mapping the JetBrains default shortcut scheme onto VibeIDE commands.",
  "version": "1.0.0",
  "publisher": "vibeide",
  "license": "MIT",
  "categories": [
    "Keymaps"
  ],
  "engines": {
    "vscode": "*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/VibeIDETeam/VibeIDE"
  },
  "contributes": {
    "keybindings": [
      {
        "key": "enter",
        "mac": "enter",
        "command": "acceptSelectedSuggestion",
        "when": "!inlineEditIsVisible && !inInlineEditsPreviewEditor && acceptSuggestionOnEnter && suggestWidgetVisible && suggestionMakesTextEdit && textInputFocus"
      },
      {
        "key": "tab",
        "mac": "tab",
        "command": "acceptAlternativeSelectedSuggestion",
        "when": "!inlineEditIsVisible && !inInlineEditsPreviewEditor && acceptSuggestionOnEnter && suggestWidgetVisible && textInputFocus"
      },
      {
        "key": "ctrl+shift+enter",
        "mac": "cmd+shift+enter",
        "command": "runCommands",
        "args": {
          "commands": [
            "acceptSelectedSuggestion",
            {
              "command": "cursorMove",
              "args": {
                "to": "wrappedLineEnd"
              }
            },
            {
              "command": "editor.action.insertSnippet",
              "args": {
                "snippet": ";"
              }
            }
          ]
        },
        "when": "suggestWidgetVisible && textInputFocus && (editorLangId == 'javascript' || editorLangId == 'typescript') && config.javascript.format.semicolons == 'insert'"
      },
      {
        "key": "ctrl+shift+enter",
        "mac": "cmd+shift+enter",
        "command": "acceptSelectedSuggestion",
        "when": "suggestWidgetVisible && textInputFocus"
      },
      {
        "key": "ctrl+p",
        "mac": "cmd+p",
        "command": "editor.action.triggerParameterHints",
        "when": "editorHasSignatureHelpProvider && editorTextFocus"
      },
      {
        "key": "ctrl+q",
        "mac": "ctrl+j",
        "command": "editor.action.showHover",
        "when": "editorTextFocus"
      },
      {
        "mac": "f1",
        "command": "editor.action.showHover",
        "when": "editorTextFocus"
      },
      {
        "key": "ctrl+f1",
        "mac": "cmd+f1",
        "command": "workbench.action.showErrorsWarnings",
        "when": "editorTextFocus"
      },
      {
        "key": "alt+insert",
        "mac": "cmd+n",
        "command": "editor.action.sourceAction",
        "when": "editorHasCodeActionsProvider && editorTextFocus && !editorReadonly"
      },
      {
        "key": "alt+insert",
        "mac": "cmd+n",
        "command": "workbench.action.files.newUntitledFile",
        "when": "(!editorHasCodeActionsProvider && editorTextFocus) || !editorTextFocus"
      },
      {
        "key": "ctrl+o",
        "mac": "ctrl+o",
        "command": "editor.action.codeAction",
        "args": {
          "kind": "source.overrideMethods"
        },
        "when": "editorLangId == java && javaLSReady && editorTextFocus"
      },
      {
        "key": "ctrl+i",
        "mac": "ctrl+i",
        "command": "editor.action.codeAction",
        "args": {
          "kind": "source.overrideMethods"
        },
        "when": "editorLangId == java && javaLSReady && editorTextFocus"
      },
      {
        "key": "ctrl+/",
        "mac": "cmd+/",
        "command": "editor.action.commentLine",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "key": "ctrl+numpad_divide",
        "mac": "cmd+numpad_divide",
        "command": "editor.action.commentLine",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "key": "ctrl+shift+/",
        "mac": "cmd+alt+/",
        "command": "editor.action.blockComment",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "key": "ctrl+shift+numpad_divide",
        "mac": "cmd+alt+numpad_divide",
        "command": "editor.action.blockComment",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "key": "ctrl+w",
        "mac": "alt+up",
        "command": "editor.action.smartSelect.grow",
        "when": "editorTextFocus"
      },
      {
        "mac": "alt+up",
        "command": "notebook.cell.moveUp",
        "when": "notebookEditorFocused && !inputFocus"
      },
      {
        "key": "ctrl+shift+w",
        "mac": "alt+down",
        "command": "editor.action.smartSelect.shrink",
        "when": "editorTextFocus"
      },
      {
        "mac": "alt+down",
        "command": "notebook.cell.moveDown",
        "when": "notebookEditorFocused && !inputFocus"
      },
      {
        "key": "alt+enter",
        "mac": "alt+enter",
        "command": "editor.action.quickFix",
        "when": "editorHasCodeActionsProvider && editorTextFocus && !editorReadonly"
      },
      {
        "key": "alt+enter",
        "mac": "alt+enter",
        "command": "notebook.cell.executeAndInsertBelow",
        "when": "notebookCellListFocused && notebookCellType == 'markup' || notebookCellListFocused && notebookMissingKernelExtension && !notebookCellExecuting && notebookCellType == 'code' || notebookCellListFocused && !notebookCellExecuting && notebookCellType == 'code' && notebookKernelCount > 0 || notebookCellListFocused && !notebookCellExecuting && notebookCellType == 'code' && notebookKernelSourceCount > 0"
      },
      {
        "key": "ctrl+alt+l",
        "mac": "cmd+alt+l",
        "command": "notebook.formatCell",
        "when": "editorHasDocumentFormattingProvider && editorTextFocus && inCompositeEditor && notebookEditable && !editorReadonly && activeEditor == 'workbench.editor.notebook'"
      },
      {
        "key": "ctrl+alt+l",
        "mac": "cmd+alt+l",
        "command": "editor.action.formatDocument",
        "when": "editorHasDocumentFormattingProvider && editorTextFocus && !editorReadonly && !inCompositeEditor"
      },
      {
        "key": "ctrl+alt+l",
        "mac": "cmd+alt+l",
        "command": "editor.action.formatDocument.none",
        "when": "editorTextFocus && !editorHasDocumentFormattingProvider && !editorReadonly"
      },
      {
        "key": "ctrl+alt+l",
        "mac": "cmd+alt+l",
        "command": "editor.action.formatSelection",
        "when": "editorHasDocumentSelectionFormattingProvider && editorHasSelection && editorTextFocus && !editorReadonly"
      },
      {
        "key": "ctrl+alt+l",
        "mac": "cmd+alt+l",
        "command": "notebook.format",
        "when": "notebookEditable && !editorTextFocus && activeEditor == 'workbench.editor.notebook'"
      },
      {
        "key": "ctrl+alt+o",
        "mac": "ctrl+alt+o",
        "command": "editor.action.organizeImports",
        "when": "editorTextFocus && !editorReadonly && supportedCodeAction =~ /(\\s|^)source\\.organizeImports\\b/"
      },
      {
        "key": "ctrl+x",
        "mac": "cmd+x",
        "command": "editor.action.clipboardCutAction",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "key": "shift+delete",
        "mac": "cmd+delete",
        "command": "editor.action.clipboardCutAction",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "key": "ctrl+d",
        "mac": "cmd+d",
        "command": "editor.action.copyLinesDownAction",
        "when": "editorTextFocus && !editorReadonly && !editorHasSelection"
      },
      {
        "key": "ctrl+d",
        "mac": "cmd+d",
        "command": "editor.action.duplicateSelection",
        "when": "editorTextFocus && !editorReadonly && editorHasSelection"
      },
      {
        "key": "ctrl+y",
        "mac": "cmd+backspace",
        "command": "editor.action.deleteLines",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "key": "ctrl+shift+j",
        "mac": "ctrl+shift+j",
        "command": "editor.action.joinLines",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "command": "lineBreakInsert",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "command": "notebook.cell.insertCodeCellBelow",
        "when": "notebookCellListFocused && !inputFocus"
      },
      {
        "key": "shift+enter",
        "mac": "shift+enter",
        "command": "editor.action.insertLineAfter",
        "when": "editorTextFocus && !editorReadonly && !notebookEditorFocused"
      },
      {
        "key": "shift+enter",
        "mac": "shift+enter",
        "command": "notebook.cell.executeAndSelectBelow",
        "when": "notebookCellListFocused && notebookCellType == 'markup' || notebookCellListFocused && notebookMissingKernelExtension && !notebookCellExecuting && notebookCellType == 'code' || notebookCellListFocused && !notebookCellExecuting && notebookCellType == 'code' && notebookKernelCount > 0 || notebookCellListFocused && !notebookCellExecuting && notebookCellType == 'code' && notebookKernelSourceCount > 0"
      },
      {
        "key": "ctrl+right",
        "mac": "alt+right",
        "command": "cursorWordRight",
        "when": "editorTextFocus && !inlineSuggestionVisible"
      },
      {
        "key": "ctrl+left",
        "mac": "alt+left",
        "command": "cursorWordLeft",
        "when": "editorTextFocus"
      },
      {
        "key": "ctrl+shift+right",
        "mac": "alt+shift+right",
        "command": "cursorWordRightSelect",
        "when": "editorTextFocus"
      },
      {
        "key": "ctrl+shift+left",
        "mac": "alt+shift+left",
        "command": "cursorWordLeftSelect",
        "when": "editorTextFocus"
      },
      {
        "key": "ctrl+delete",
        "mac": "alt+delete",
        "command": "deleteWordRight",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "key": "ctrl+backspace",
        "mac": "alt+backspace",
        "command": "deleteWordLeft",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "key": "ctrl+.",
        "mac": "cmd+.",
        "command": "editor.toggleFold",
        "when": "editorFocus && foldingEnabled"
      },
      {
        "key": "ctrl+=",
        "mac": "cmd+=",
        "command": "editor.unfold",
        "when": "editorFocus && foldingEnabled"
      },
      {
        "key": "ctrl+numpad_add",
        "mac": "cmd+numpad_add",
        "command": "editor.unfold",
        "when": "editorFocus && foldingEnabled"
      },
      {
        "key": "ctrl+-",
        "mac": "cmd+-",
        "command": "editor.fold",
        "when": "editorFocus && foldingEnabled"
      },
      {
        "key": "ctrl+numpad_subtract",
        "mac": "cmd+numpad_subtract",
        "command": "editor.fold",
        "when": "editorFocus && foldingEnabled"
      },
      {
        "key": "ctrl+alt+=",
        "mac": "cmd+alt+=",
        "command": "editor.unfoldRecursively",
        "when": "editorFocus && foldingEnabled"
      },
      {
        "key": "ctrl+alt+numpad_add",
        "mac": "cmd+alt+numpad_add",
        "command": "editor.unfoldRecursively",
        "when": "editorFocus && foldingEnabled"
      },
      {
        "key": "ctrl+alt+-",
        "mac": "cmd+alt+-",
        "command": "editor.foldRecursively",
        "when": "editorFocus && foldingEnabled"
      },
      {
        "key": "ctrl+alt+numpad_subtract",
        "mac": "cmd+alt+numpad_subtract",
        "command": "editor.foldRecursively",
        "when": "editorFocus && foldingEnabled"
      },
      {
        "key": "ctrl+shift+=",
        "mac": "cmd+shift+=",
        "command": "editor.unfoldAll",
        "when": "editorFocus && foldingEnabled"
      },
      {
        "key": "ctrl+shift+numpad_add",
        "mac": "cmd+shift+numpad_add",
        "command": "editor.unfoldAll",
        "when": "editorFocus && foldingEnabled"
      },
      {
        "key": "ctrl+shift+-",
        "mac": "cmd+shift+-",
        "command": "editor.foldAll",
        "when": "editorFocus && foldingEnabled"
      },
      {
        "key": "ctrl+shift+numpad_subtract",
        "mac": "cmd+shift+numpad_subtract",
        "command": "editor.foldAll",
        "when": "editorFocus && foldingEnabled"
      },
      {
        "key": "ctrl+f4",
        "mac": "cmd+w",
        "command": "workbench.action.closeActiveEditor"
      },
      {
        "key": "alt+j",
        "mac": "ctrl+g",
        "command": "editor.action.addSelectionToNextFindMatch",
        "when": "editorFocus"
      },
      {
        "key": "alt+shift+j",
        "mac": "ctrl+shift+g",
        "command": "cursorUndo",
        "when": "editorTextFocus"
      },
      {
        "key": "shift+alt+down",
        "mac": "shift+alt+down",
        "command": "editor.action.moveLinesDownAction",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "key": "shift+alt+down",
        "mac": "shift+alt+down",
        "command": "notebook.cell.copyDown",
        "when": "notebookEditorFocused && !inputFocus"
      },
      {
        "key": "shift+alt+up",
        "mac": "shift+alt+up",
        "command": "editor.action.moveLinesUpAction",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "key": "shift+alt+insert",
        "mac": "shift+cmd+8",
        "command": "editor.action.toggleColumnSelection"
      },
      {
        "key": "shift+alt+.",
        "mac": "shift+ctrl+.",
        "command": "editor.action.fontZoomIn",
        "when": "editorTextFocus"
      },
      {
        "key": "shift+alt+,",
        "mac": "shift+ctrl+,",
        "command": "editor.action.fontZoomOut",
        "when": "editorTextFocus"
      },
      {
        "key": "shift shift",
        "mac": "shift shift",
        "command": "workbench.action.quickOpen"
      },
      {
        "key": "f3",
        "mac": "cmd+g",
        "command": "editor.action.nextMatchFindAction",
        "when": "editorFocus"
      },
      {
        "key": "shift+f3",
        "mac": "cmd+shift+g",
        "command": "editor.action.previousMatchFindAction",
        "when": "editorFocus"
      },
      {
        "key": "ctrl+r",
        "mac": "cmd+r",
        "command": "editor.action.startFindReplaceAction",
        "when": "editorFocus || editorIsOpen"
      },
      {
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f",
        "command": "workbench.action.findInFiles",
        "when": "!explorerResourceIsFolder || !filesExplorerFocus"
      },
      {
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f",
        "command": "filesExplorer.findInFolder",
        "when": "explorerResourceIsFolder && filesExplorerFocus"
      },
      {
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "command": "workbench.action.replaceInFiles"
      },
      {
        "key": "alt+f7",
        "mac": "alt+f7",
        "command": "references-view.findReferences",
        "when": "editorHasReferenceProvider"
      },
      {
        "key": "alt+ctrl+f7",
        "mac": "alt+cmd+f7",
        "command": "editor.action.referenceSearch.trigger",
        "when": "editorHasReferenceProvider && editorTextFocus && !inReferenceSearchEditor"
      },
      {
        "mac": "ctrl+alt+down",
        "command": "editor.action.wordHighlight.next",
        "when": "editorTextFocus && hasWordHighlights"
      },
      {
        "mac": "ctrl+alt+up",
        "command": "editor.action.wordHighlight.prev",
        "when": "editorTextFocus && hasWordHighlights"
      },
      {
        "key": "ctrl+f9",
        "mac": "cmd+f9",
        "command": "workbench.action.tasks.build"
      },
      {
        "key": "alt+shift+f10",
        "mac": "ctrl+alt+r",
        "command": "workbench.action.tasks.runTask",
        "when": "taskCommandsRegistered && !terminalFocus"
      },
      {
        "key": "alt+shift+f9",
        "mac": "ctrl+alt+d",
        "command": "workbench.view.debug"
      },
      {
        "key": "shift+f10",
        "mac": "ctrl+r",
        "command": "workbench.action.tasks.reRunTask",
        "when": "taskCommandsRegistered && !terminalFocus"
      },
      {
        "key": "shift+f9",
        "mac": "ctrl+d",
        "command": "workbench.action.debug.run",
        "when": "debuggersAvailable && !inDebugMode && !terminalFocus"
      },
      {
        "key": "ctrl+f2",
        "mac": "cmd+f2",
        "command": "workbench.action.debug.stop",
        "when": "inDebugMode && !focusedSessionIsAttach"
      },
      {
        "key": "f8",
        "mac": "f8",
        "command": "workbench.action.debug.stepOver",
        "when": "debugState == 'stopped'"
      },
      {
        "key": "f7",
        "mac": "f7",
        "command": "workbench.action.debug.stepInto",
        "when": "debugState != 'inactive'"
      },
      {
        "key": "shift+f8",
        "mac": "shift+f8",
        "command": "workbench.action.debug.stepOut",
        "when": "debugState == 'stopped'"
      },
      {
        "key": "alt+f9",
        "mac": "alt+f9",
        "command": "editor.debug.action.runToCursor",
        "when": "debugState == 'stopped'"
      },
      {
        "key": "alt+f8",
        "mac": "alt+f8",
        "command": "workbench.debug.action.toggleRepl",
        "when": "debuggersAvailable"
      },
      {
        "key": "alt+f8",
        "mac": "alt+f8",
        "command": "editor.debug.action.selectionToRepl",
        "when": "debuggersAvailable && editorTextFocus && editorHasSelection"
      },
      {
        "key": "f9",
        "mac": "cmd+alt+r",
        "command": "workbench.action.debug.continue",
        "when": "inDebugMode"
      },
      {
        "key": "ctrl+f8",
        "mac": "cmd+f8",
        "command": "editor.debug.action.toggleBreakpoint",
        "when": "debuggersAvailable && editorTextFocus"
      },
      {
        "key": "ctrl+shift+f8",
        "mac": "cmd+shift+f8",
        "command": "workbench.debug.action.focusBreakpointsView"
      },
      {
        "key": "ctrl+n",
        "mac": "cmd+o",
        "command": "workbench.action.showAllSymbols"
      },
      {
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+o",
        "command": "workbench.action.quickOpen"
      },
      {
        "key": "ctrl+alt+shift+n",
        "mac": "cmd+alt+o",
        "command": "workbench.action.gotoSymbol",
        "when": "editorTextFocus"
      },
      {
        "key": "alt+left",
        "mac": "ctrl+left",
        "command": "workbench.action.previousEditor",
        "when": "!terminalFocus"
      },
      {
        "mac": "shift+cmd+[",
        "command": "workbench.action.previousEditor",
        "when": "!terminalFocus"
      },
      {
        "key": "alt+right",
        "mac": "ctrl+right",
        "command": "workbench.action.nextEditor",
        "when": "!terminalFocus"
      },
      {
        "mac": "shift+cmd+]",
        "command": "workbench.action.nextEditor",
        "when": "!terminalFocus"
      },
      {
        "key": "shift+escape",
        "mac": "shift+escape",
        "command": "workbench.action.toggleSidebarVisibility",
        "when": "sideBarFocus"
      },
      {
        "key": "shift+escape",
        "mac": "shift+escape",
        "command": "workbench.action.toggleAuxiliaryBar",
        "when": "auxiliaryBarFocus"
      },
      {
        "key": "shift+escape",
        "mac": "shift+escape",
        "command": "workbench.action.togglePanel",
        "when": "panelFocus"
      },
      {
        "key": "ctrl+shift+'",
        "mac": "cmd+shift+'",
        "command": "workbench.action.toggleMaximizedPanel",
