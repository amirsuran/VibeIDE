	// .vibe/providers.json — пользовательские определения провайдеров (JSONC, комментарии разрешены).
	// Схема: src/vs/workbench/contrib/vibeide/common/vibeProvidersFile.ts
	"version": 1,
	"providers": [
		{
			"id": "zai",
			"name": "Z.AI (GLM)",
			"protocol": "openai",
			"baseURL": "https://api.z.ai/api/paas/v4",
			"auth": "bearer",
			// Ключ хранится вне файла: переменная окружения ZAI_API_KEY (.vibe/.env или process.env).
			"apiKeyEnv": "ZAI_API_KEY",
			"docsUrl": "https://docs.z.ai/",
			"apiKeyUrl": "https://z.ai/manage-apikey/apikey-list",
			"order": 50,
			"tags": ["glm", "zhipu"],
			"models": {
				// Список моделей z.ai лежит на <baseURL>/models, а не /v1/models — задаём URL явно.
				"fetch": "https://api.z.ai/api/paas/v4/models",
				// Статический fallback (используется, пока каталог не подтянулся / нет ключа).
