// Moonshot / Kimi — OpenAI-совместимый API, «думающая» модель.
// Рецепт reasoning: слайдер усилия (reasoning.effort → reasoning_effort) + сам режим
// thinking у Moonshot включается отдельным полем в extraBody (уходит в тело как есть).
// Ключ: MOONSHOT_API_KEY=<ключ> в .vibe/.env.
{
	"version": 1,
	"providers": [
		{
			"id": "kimi",
			"name": "Kimi (Moonshot)",
			"protocol": "openai",
			"baseURL": "https://api.moonshot.ai/v1",
			"auth": "bearer",
			"apiKeyEnv": "MOONSHOT_API_KEY",
			"apiKeyUrl": "https://platform.moonshot.ai/console/api-keys",
			"order": 60,
			"models": {
				"fetch": true,
				"static": [
					{
						"id": "kimi-k2.7-code",
						"name": "Kimi K2.7 Code",
						"default": true,
						"contextWindow": 262144,
						"maxOutputTokens": 32768,
						"toolFormat": "openai",
						"reasoning": { "canTurnOff": true, "effort": ["low", "medium", "high"] },
						"extraBody": { "thinking": { "type": "enabled" } }
					}
				]
			}
		}
	]
}
