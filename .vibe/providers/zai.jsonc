// Z.AI (Zhipu / GLM) — OpenAI-совместимый API.
// Скопируйте в .vibe/providers.json (или перенесите объект провайдера в свой массив providers).
// Ключ: положите строку ZAI_API_KEY=<ваш-ключ> в .vibe/.env (не коммитится).
// Coding Plan: смените baseURL и models.fetch на https://api.z.ai/api/coding/paas/v4(/models).
{
	"version": 1,
	"providers": [
		{
			"id": "zai",
			"name": "Z.AI (GLM)",
			"protocol": "openai",
			"baseURL": "https://api.z.ai/api/paas/v4",
			"auth": "bearer",
			"apiKeyEnv": "ZAI_API_KEY",
			"docsUrl": "https://docs.z.ai/",
			"apiKeyUrl": "https://z.ai/manage-apikey/apikey-list",
			"order": 50,
			"tags": ["glm", "zhipu"],
			"models": {
				// Каталог z.ai — на <baseURL>/models, не /v1/models → указываем полный URL.
				"fetch": "https://api.z.ai/api/paas/v4/models",
				// Статический fallback (пока каталог не подтянулся / нет ключа).
				"static": [
					{
						"id": "glm-4.6",
						"name": "GLM-4.6",
						"default": true,
						"pinned": true,
						"contextWindow": 200000,
						"maxOutputTokens": 131072,
						"toolFormat": "openai",
						"systemMessage": "system",
						"reasoning": { "canTurnOff": true, "field": "thinking" }
					},
					{
						"id": "glm-4.5",
						"name": "GLM-4.5",
						"contextWindow": 131072,
						"maxOutputTokens": 98304,
						"toolFormat": "openai",
						"systemMessage": "system",
						"reasoning": { "canTurnOff": true, "field": "thinking" }
					},
					{
						"id": "glm-4.5-air",
						"name": "GLM-4.5-Air",
						"contextWindow": 131072,
						"maxOutputTokens": 98304,
						"toolFormat": "openai",
						"systemMessage": "system",
						"reasoning": { "canTurnOff": true, "field": "thinking" }
					},
					{
						"id": "glm-4.5v",
						"name": "GLM-4.5V (vision)",
						"contextWindow": 65536,
						"maxOutputTokens": 16384,
						"toolFormat": "openai",
						"vision": true,
						"systemMessage": "system"
					},
					{
						"id": "glm-4.5-flash",
						"name": "GLM-4.5-Flash",
						"contextWindow": 131072,
						"maxOutputTokens": 98304,
						"toolFormat": "openai",
						"systemMessage": "system"
					}
				]
			}
		}
	]
}
