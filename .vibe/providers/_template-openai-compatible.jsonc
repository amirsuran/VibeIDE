// Шаблон: свой OpenAI-совместимый провайдер «с нуля».
// Замените id/name/baseURL/apiKeyEnv на свои. auth: "bearer" | { "type":"header","name":"x-api-key" } | { "type":"query","name":"key" }.
// models.fetch: true — авто-список из <baseURL>/v1/models; строка — свой URL каталога; false — только static.
{
	"version": 1,
	"providers": [
		{
			"id": "my-provider",
			"name": "Мой провайдер",
			"protocol": "openai",
			"baseURL": "https://api.example.com/v1",
			"auth": "bearer",
			"apiKeyEnv": "MY_PROVIDER_API_KEY",
			"order": 100,
			"models": {
				"fetch": true,
				"static": [
					{
						"id": "model-id-from-provider",
						"name": "Моя модель",
						"default": true,
						"contextWindow": 128000,
						"maxOutputTokens": 16384,
						"toolFormat": "openai",
						"systemMessage": "system"
					}
				]
			}
		}
	]
}
